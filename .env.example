# ============================================
# Answers Platform - Environment Configuration
# ============================================

# --------------------------------------------
# Database Configuration
# --------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/answers_db
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# LLM Providers Configuration
# Multiple providers with automatic fallback
# Priority: GROQ -> OPENROUTER -> QWEN -> OLLAMA -> HUGGINGFACE
# --------------------------------------------

# --- Groq (Recommended - Fastest Free Tier) ---
# Sign up: https://console.groq.com/
# Free tier: 30 req/min, 200 req/day
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenRouter (Free Models Available) ---
# Sign up: https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# --- Qwen API (Self-hosted or Alibaba Cloud) ---
# Can be shared across multiple projects!
# Option 1: Self-hosted with vLLM/TGI/Ollama
# Option 2: Alibaba Cloud DashScope API
# 
# For self-hosted (OpenAI-compatible API):
QWEN_API_BASE_URL=http://your-qwen-server:8000/v1
QWEN_API_KEY=  # Optional, if using authentication
QWEN_MODEL=qwen2.5-7b-instruct
#
# Example configurations:
# Local vLLM: http://localhost:8000/v1
# Remote server: http://192.168.1.100:8000/v1
# Alibaba Cloud: https://dashscope.aliyuncs.com/api/v1

# --- Ollama (Local - Completely Free) ---
# Install: https://ollama.ai/
# Start: ollama serve
# Pull model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Hugging Face Inference API (Fallback) ---
# Sign up: https://huggingface.co/
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta

# --------------------------------------------
# RAG Configuration
# --------------------------------------------
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHUNK_SIZE=400
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5

# --------------------------------------------
# Cache Configuration
# --------------------------------------------
CACHE_TTL=86400

# --------------------------------------------
# Frontend Configuration
# --------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
